{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Downloader",
  "version": "0.1.0",
  "identifier": "dev.local.downloader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Downloader",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$DOWNLOAD/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "appimage", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFNUI1MkJBMjQzOUE3MzMKUldRenB6a2t1bEpiamd6RjhiOStNcXpaZm56MmRDWmlxUmRSN3BHdnRmYlRKbkMydmRmK0c2MzUK",
      "endpoints": [
        "https://github.com/ArionStudio/local-downloader/releases/latest/download/latest.json"
      ]
    }
  }
}
